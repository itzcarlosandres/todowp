# =====================================================
# Application
# =====================================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TodoWP

# =====================================================
# Database (PostgreSQL)
# =====================================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/todowp?schema=public"
SHADOW_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/todowp_shadow?schema=public"

# =====================================================
# Redis
# =====================================================
REDIS_URL="redis://localhost:6379"
REDIS_PREFIX="todowp:"

# =====================================================
# Auth (NextAuth v5)
# =====================================================
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# =====================================================
# Email (Nodemailer)
# =====================================================
SMTP_HOST="smtp.mailhog.example"
SMTP_PORT=1025
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_NAME="TodoWP"
SMTP_FROM_EMAIL="no-reply@todowp.example"

# =====================================================
# Storage (Cloudflare R2 / S3)
# =====================================================
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="todowp-files"
R2_PUBLIC_URL="https://files.todowp.example"
R2_ENDPOINT=""

# =====================================================
# Payments
# =====================================================
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""
PAYPAL_MODE="sandbox"

MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
MERCADOPAGO_WEBHOOK_SECRET=""

BINANCE_PAY_API_KEY=""
BINANCE_PAY_SECRET_KEY=""
BINANCE_PAY_MERCHANT_ID=""

# =====================================================
# AI (optional)
# =====================================================
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# =====================================================
# Analytics
# =====================================================
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""

# =====================================================
# Rate Limiting (Upstash optional)
# =====================================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
