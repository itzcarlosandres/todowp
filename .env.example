# =====================================================
# TodoWP - Production Environment Variables for Easypanel
# =====================================================
# Copia este archivo como guía para configurar las variables
# de entorno en Easypanel (Settings -> Environment Variables)
#
# Para generar AUTH_SECRET ejecuta en tu terminal:
#   openssl rand -base64 32
# =====================================================

# =====================================================
# Application (REQUIRED)
# =====================================================
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://YOUR-EASYPANEL-DOMAIN.easypanel.host
NEXT_PUBLIC_APP_NAME=TodoWP

# =====================================================
# Database (REQUIRED) - Easypanel provisiona PostgreSQL
# =====================================================
# El servicio postgres es interno. Usa el nombre del servicio como host.
# En Easypanel: postgres://postgres:PASSWORD@postgres:5432/todowp
DATABASE_URL="postgresql://postgres:CHANGE_ME@postgres:5432/todowp?schema=public"
SHADOW_DATABASE_URL="postgresql://postgres:CHANGE_ME@postgres:5432/todowp_shadow?schema=public"

# =====================================================
# Redis (OPTIONAL - la app funciona sin él, usa cache no-op)
# =====================================================
# REDIS_URL="redis://redis:6379"
# REDIS_PREFIX="todowp:"

# =====================================================
# Auth (REQUIRED)
# =====================================================
# Genera uno nuevo con: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_OPENSSL_RAND_BASE64_32"
AUTH_URL="https://YOUR-EASYPANEL-DOMAIN.easypanel.host"
AUTH_TRUST_HOST=true

# OAuth Providers (OPTIONAL - déjalos vacíos si no los usas)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# =====================================================
# Email / SMTP (OPTIONAL pero recomendado)
# =====================================================
# Ejemplos de proveedores:
#   - Resend: smtp.resend.com
#   - Brevo: smtp-relay.brevo.com
#   - Mailgun: smtp.mailgun.org
#   - SendGrid: smtp.sendgrid.net
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM_NAME="TodoWP"
SMTP_FROM_EMAIL="no-reply@yourdomain.com"

# =====================================================
# Storage (Cloudflare R2 / S3) - OPCIONAL
# =====================================================
# Si NO configuras estas variables, la app usa almacenamiento local
# (carpeta ./storage para productos, ./public/uploads para imágenes).
# Si configuras TODAS las requeridas (ACCOUNT_ID, ACCESS_KEY_ID,
# SECRET_ACCESS_KEY, BUCKET), la app usa R2 automáticamente.
# Requeridas para activar R2:
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="todowp-files"
# Opcionales (con valores por defecto razonables):
R2_ENDPOINT=""              # Por defecto: https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=""            # Tu CDN público para servir archivos (opcional)
# Carpeta local para productos cuando R2 no está activo (default: ./storage)
# LOCAL_STORAGE_DIR="storage"

# =====================================================
# Payments (OPTIONAL - al menos uno para vender)
# =====================================================
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PUBLISHABLE_KEY=""

PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""
PAYPAL_MODE="live"

MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
MERCADOPAGO_WEBHOOK_SECRET=""

BINANCE_PAY_API_KEY=""
BINANCE_PAY_SECRET_KEY=""
BINANCE_PAY_MERCHANT_ID=""

# =====================================================
# AI (OPTIONAL)
# =====================================================
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""

# =====================================================
# Analytics (OPTIONAL)
# =====================================================
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""

# =====================================================
# Rate Limiting - Upstash (OPTIONAL)
# =====================================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
