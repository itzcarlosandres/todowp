  "faq": {
    "items": [
      {
        "question": "How do I download my products?",
        "answer": "After purchasing, you'll receive an email with the download links. You can also access them anytime from your user dashboard under the 'Downloads' section."
      },
      {
        "question": "Do licenses expire?",
        "answer": "No, all licenses are perpetual. Buy once and use the product forever, including all future updates."
      },
      {
        "question": "Can I use the products in commercial projects?",
        "answer": "Yes, all our licenses allow commercial use. The single license is for one site and the unlimited for unlimited projects."
      },
      {
        "question": "Do you offer technical support?",
        "answer": "Yes, we offer premium support for 6 months included with each purchase. You can extend the support anytime."
      },
      {
        "question": "How do updates work?",
        "answer": "Updates are free for life. We'll notify you by email whenever a new version is available."
      },
      {
        "question": "What payment methods do you accept?",
        "answer": "We accept credit/debit card (Stripe), PayPal, MercadoPago, Binance Pay, cryptocurrencies and bank transfer."
      }
    ]
  }
